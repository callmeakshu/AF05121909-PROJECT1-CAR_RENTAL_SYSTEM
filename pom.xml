#!/usr/bin/env bash
# ---------------------------------------------------------------------
# Compile + run the Car Rental Management System.
#
# Place the MySQL JDBC driver jar in ./lib  e.g.
#     lib/mysql-connector-j-8.4.0.jar
# (For PostgreSQL: lib/postgresql-42.7.4.jar and edit db.properties)
# ---------------------------------------------------------------------
set -e
cd "$(dirname "$0")"

mkdir -p out
JARS="$(ls lib/*.jar 2>/dev/null | tr '\n' ':')"
CP="out:src/main/resources:${JARS}"

echo ">> Compiling..."
find src/main/java -name '*.java' > sources.txt
javac -d out -cp "${JARS}" @sources.txt
rm sources.txt

echo ">> Running..."
java -cp "${CP}" com.carrental.Main
